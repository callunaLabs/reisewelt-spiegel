---
interface Props {
  variant?: 'simple' | 'full';
}
const { variant = 'simple' } = Astro.props;
---

{variant === 'full' ? (
<footer class="w-full bg-neutral-50 border-t border-neutral-200 mt-20">
  <div class="max-w-7xl mx-auto py-16 px-8 grid grid-cols-1 md:grid-cols-4 gap-12">
    <div>
      <p class="font-headline font-black text-lg text-neutral-900 uppercase mb-4">Reisewelt Editorial</p>
      <p class="font-body italic text-sm text-neutral-500 leading-relaxed">Kuratierte Reisemomente für den modernen Entdecker. Ein Magazin von SPIEGEL.</p>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Reisen</h4>
      <ul class="space-y-3">
        <li><a href="/rundreisen" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Rundreisen</a></li>
        <li><a href="/genussreisen" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Genussreisen</a></li>
        <li><a href="/reisetrends" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Reisetrends</a></li>
        <li><a href="/suche" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Suche</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Magazin</h4>
      <ul class="space-y-3">
        <li><a href="/reisetrends/reisetrends-2026" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Reisetrends 2026</a></li>
        <li><a href="/reisetrends/eventkreuzfahrten" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Eventkreuzfahrten</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Unternehmen</h4>
      <ul class="space-y-3">
        <li><a href="/ueber-uns" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">&Uuml;ber uns</a></li>
        <li><a href="/impressum" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Impressum</a></li>
        <li><a href="/datenschutz" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Datenschutz</a></li>
        <li><a href="/kontakt" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Kontakt</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-neutral-200 py-8 px-8">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-sm italic text-neutral-400">&copy; {new Date().getFullYear()} Reisewelt Editorial. Alle Rechte vorbehalten.</p>
      <div style="display:flex;gap:12px;">
        <a href="mailto:reisewelt.service@spiegel.de" style="width:36px;height:36px;border-radius:50%;border:1px solid #e5e5e5;display:flex;align-items:center;justify-content:center;color:#999;text-decoration:none;" aria-label="E-Mail">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a href="https://www.spiegel.de/schlagzeilen/index.rss" style="width:36px;height:36px;border-radius:50%;border:1px solid #e5e5e5;display:flex;align-items:center;justify-content:center;color:#999;text-decoration:none;" aria-label="RSS Feed">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
) : (
<footer class="w-full border-t border-neutral-200 bg-neutral-50 py-12 px-8">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-lg font-black text-neutral-900 font-headline">Reisewelt Editorial</div>
    <p class="font-body text-sm italic text-neutral-500">&copy; {new Date().getFullYear()} Reisewelt Editorial. Alle Rechte vorbehalten.</p>
    <div class="flex gap-6">
      <a href="/impressum" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Impressum</a>
      <a href="/datenschutz" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Datenschutz</a>
      <a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">AGB</a>
      <a href="/kontakt" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Kontakt</a>
    </div>
  </div>
</footer>
)}
