---
interface Props {
  variant?: 'simple' | 'full';
}
const { variant = 'simple' } = Astro.props;
---

{variant === 'full' ? (
<footer class="w-full bg-neutral-50 border-t border-neutral-200 mt-20">
  <div class="max-w-7xl mx-auto py-16 px-8 grid grid-cols-1 md:grid-cols-4 gap-12">
    <div>
      <p class="font-headline font-black text-lg text-neutral-900 uppercase mb-4">Reisewelt Editorial</p>
      <p class="font-body italic text-sm text-neutral-500 leading-relaxed">Kuratierte Reisemomente für den modernen Entdecker. Ein Magazin von SPIEGEL.</p>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Reiseziele</h4>
      <ul class="space-y-3">
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Indischer Ozean</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Skandinavien</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Südostasien</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Alpenraum</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Magazin</h4>
      <ul class="space-y-3">
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Interviews</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Fotostrecken</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Packlisten</a></li>
        <li><a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Slow Travel</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-6 text-[#E64415]">Unternehmen</h4>
      <ul class="space-y-3">
        <li><a href="/impressum" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Impressum</a></li>
        <li><a href="/datenschutz" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Datenschutz</a></li>
        <li><a href="/kontakt" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Kontakt</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-neutral-200 py-8 px-8">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-sm italic text-neutral-400">&copy; {new Date().getFullYear()} Reisewelt Editorial. Alle Rechte vorbehalten.</p>
      <div class="flex gap-4">
        <a href="#" class="w-10 h-10 rounded-full border border-neutral-200 flex items-center justify-center text-neutral-400 hover:text-[#E64415] hover:border-[#E64415] transition-all">
          <span class="material-symbols-outlined text-sm">mail</span>
        </a>
        <a href="#" class="w-10 h-10 rounded-full border border-neutral-200 flex items-center justify-center text-neutral-400 hover:text-[#E64415] hover:border-[#E64415] transition-all">
          <span class="material-symbols-outlined text-sm">rss_feed</span>
        </a>
      </div>
    </div>
  </div>
</footer>
) : (
<footer class="w-full border-t border-neutral-200 bg-neutral-50 py-12 px-8">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="text-lg font-black text-neutral-900 font-headline">Reisewelt Editorial</div>
    <p class="font-body text-sm italic text-neutral-500">&copy; {new Date().getFullYear()} Reisewelt Editorial. Alle Rechte vorbehalten.</p>
    <div class="flex gap-6">
      <a href="/impressum" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Impressum</a>
      <a href="/datenschutz" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Datenschutz</a>
      <a href="#" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">AGB</a>
      <a href="/kontakt" class="font-body text-sm italic text-neutral-500 hover:text-neutral-800 hover:underline transition-all">Kontakt</a>
    </div>
  </div>
</footer>
)}
