---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-6 py-4">
  <ol class="flex items-center gap-2 flex-wrap font-headline text-xs tracking-wide">
    <li>
      <a href="/" class="text-on-surface-variant hover:text-[#E64415] transition-colors">Startseite</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        <span class="material-symbols-outlined text-outline-variant text-[14px]">chevron_right</span>
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="text-on-surface-variant hover:text-[#E64415] transition-colors">{item.label}</a>
        ) : (
          <span class="text-on-surface font-semibold">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
