---
interface Block {
  name: string;
  attrs: Record<string, any>;
  innerHTML?: string;
}

interface Props {
  blocks: Block[];
}

const { blocks = [] } = Astro.props;
---

{blocks.map((block) => {
  const a = block.attrs || {};

  if (block.name === 'reisewelt/hero') return (
    <section class="relative h-[600px] md:h-[700px] overflow-hidden">
      {a.image && <img src={a.image} alt={a.title || ''} class="absolute inset-0 w-full h-full object-cover" />}
      <div class="absolute inset-0 hero-gradient"></div>
      <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-6 pb-16">
        {a.title && <h1 class="font-headline text-4xl md:text-6xl font-black tracking-tighter text-white leading-tight max-w-3xl">{a.title}</h1>}
        {a.subtitle && <p class="font-body italic text-xl md:text-2xl text-white/90 mt-4 max-w-xl">{a.subtitle}</p>}
      </div>
    </section>
  );

  if (block.name === 'reisewelt/info-bar') return (
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex flex-wrap gap-6 md:gap-12 items-center py-6 border-y border-outline-variant/30">
        {a.preis && <div><span class="font-headline text-[10px] font-bold uppercase tracking-widest text-on-surface-variant block">Preis</span><span class="font-headline text-xl font-black text-[#E64415]">{a.preis}</span></div>}
        {a.dauer && <div><span class="font-headline text-[10px] font-bold uppercase tracking-widest text-on-surface-variant block">Dauer</span><span class="font-headline text-xl font-bold text-primary">{a.dauer}</span></div>}
        {a.destination && <div><span class="font-headline text-[10px] font-bold uppercase tracking-widest text-on-surface-variant block">Ziel</span><span class="font-headline text-xl font-bold text-primary">{a.destination}</span></div>}
        {a.kategorie && <div><span class="font-headline text-[10px] font-bold uppercase tracking-widest text-on-surface-variant block">Art</span><span class="font-headline text-lg text-primary">{a.kategorie}</span></div>}
        {a.partner && <div><span class="font-headline text-[10px] font-bold uppercase tracking-widest text-on-surface-variant block">Partner</span><span class="font-headline text-lg text-primary">{a.partner}</span></div>}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/highlights') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <h2 class="font-headline text-2xl font-black tracking-tight text-primary mb-8">{a.title || 'Highlights'}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {(a.items || []).map((item: string) => (
          <div class="flex items-start gap-3 p-4 bg-surface-container-low rounded">
            <span class="text-[#E64415] text-lg mt-0.5"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E64415" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></span>
            <span class="font-body text-on-surface">{item}</span>
          </div>
        ))}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/itinerary') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <h2 class="font-headline text-2xl font-black tracking-tight text-primary mb-8">{a.title || 'Reiseverlauf'}</h2>
      <div class="space-y-6">
        {(a.days || []).map((day: any, i: number) => (
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="w-10 h-10 rounded-full bg-[#E64415] text-white flex items-center justify-center font-headline font-bold text-sm">{i + 1}</div>
              {i < (a.days.length - 1) && <div class="w-px flex-1 bg-outline-variant/30 mt-2"></div>}
            </div>
            <div class="flex-1 pb-6">
              <h3 class="font-headline font-bold text-lg text-primary mb-2">{day.titel}</h3>
              <div class="font-body text-on-surface-variant leading-relaxed" set:html={day.beschreibung}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/gallery') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class={`grid gap-4 grid-cols-2 ${a.columns === 4 ? 'md:grid-cols-4' : a.columns === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
        {(a.images || []).map((img: any) => (
          <div class="aspect-[4/3] overflow-hidden rounded group">
            <img src={img.url} alt={img.alt || ''} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>
        ))}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/inclusions') return (
    <div class="max-w-7xl mx-auto px-6 py-12 bg-surface-container-low">
      <h2 class="font-headline text-2xl font-black tracking-tight text-primary mb-8">{a.title || 'Inklusivleistungen'}</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {(a.items || []).map((item: string) => (
          <li class="flex items-center gap-3">
            <span class="text-green-600 text-lg"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></span>
            <span class="font-body text-on-surface">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  );

  if (block.name === 'reisewelt/booking-cta') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="bg-primary p-8 md:p-12 rounded flex flex-col md:flex-row items-center justify-between gap-8">
        <div>
          {a.preis && <p class="font-headline text-3xl font-black text-white mb-2">{a.preis}</p>}
          {a.hinweis && <p class="font-body italic text-white/70">{a.hinweis}</p>}
        </div>
        <a href={a.url || '#'} target="_blank" rel="noopener" class="bg-[#E64415] hover:bg-[#ff5a2b] text-white font-headline font-bold text-[11px] tracking-widest uppercase px-12 py-5 rounded-sm transition-colors whitespace-nowrap">
          {a.buttonText || 'Jetzt buchen'}
        </a>
      </div>
    </div>
  );

  if (block.name === 'reisewelt/partner-info') return (
    <div class="max-w-7xl mx-auto px-6 py-12 border-t border-outline-variant/30">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="md:w-1/3">
          {a.logo && <img src={a.logo} alt={a.name} class="h-12 mb-4 object-contain" />}
          <h3 class="font-headline font-bold text-xl text-primary mb-2">{a.name}</h3>
          {a.telefon && <p class="font-body text-sm text-on-surface-variant"><span class="text-sm align-middle mr-1">&#9742;</span>{a.telefon}</p>}
          {a.email && <p class="font-body text-sm text-on-surface-variant"><span class="text-sm align-middle mr-1">&#9993;</span>{a.email}</p>}
          {a.website && <a href={a.website} target="_blank" class="font-headline text-sm text-[#E64415] hover:underline">{a.website}</a>}
        </div>
        {(a.usps || []).length > 0 && (
          <div class="md:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-4">
            {(a.usps || []).map((usp: string) => (
              <div class="flex items-start gap-3">
                <span class="text-[#E64415] mt-0.5"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E64415" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></span>
                <span class="font-body text-on-surface">{usp}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/price-table') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <h2 class="font-headline text-2xl font-black tracking-tight text-primary mb-8">{a.title || 'Termine & Preise'}</h2>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b-2 border-primary">
              <th class="text-left font-headline text-sm font-bold uppercase tracking-widest text-primary py-3 pr-4">Termin</th>
              <th class="text-left font-headline text-sm font-bold uppercase tracking-widest text-primary py-3 pr-4">Preis</th>
              <th class="text-left font-headline text-sm font-bold uppercase tracking-widest text-primary py-3">Status</th>
            </tr>
          </thead>
          <tbody>
            {(a.rows || []).map((row: any) => (
              <tr class="border-b border-outline-variant/30">
                <td class="font-body py-3 pr-4">{row.termin}</td>
                <td class="font-headline font-bold text-[#E64415] py-3 pr-4">{row.preis}</td>
                <td class="font-body text-on-surface-variant py-3">{row.status}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );

  if (block.name === 'reisewelt/faq') return (
    <div class="max-w-7xl mx-auto px-6 py-12">
      <h2 class="font-headline text-2xl font-black tracking-tight text-primary mb-8">{a.title || 'Häufige Fragen'}</h2>
      <div class="space-y-4">
        {(a.items || []).map((item: any) => (
          <details class="group border border-outline-variant/30 rounded overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-headline font-bold text-primary hover:bg-surface-container-low transition-colors">
              {item.frage}
              <span class="text-on-surface-variant group-open:rotate-180 transition-transform">&#9660;</span>
            </summary>
            <div class="px-6 pb-4 font-body text-on-surface-variant leading-relaxed">{item.antwort}</div>
          </details>
        ))}
      </div>
    </div>
  );

  if (block.name === 'reisewelt/bento-grid') return (
    <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem;">
      {/* Header */}
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
        <div>
          <h2 style="font-family:SpiegelSlab4UICd,Inter,sans-serif;font-size:1.75rem;font-weight:800;color:#2f2d2b;margin:0;">{a.title}</h2>
          {a.subtitle && <p style="font-family:SpiegelSerifTextUI,Newsreader,serif;font-style:italic;color:#807e7c;margin-top:0.5rem;">{a.subtitle}</p>}
        </div>
        {(a.filters || []).length > 0 && (
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            {(a.filters || []).map((f: string) => (
              <span style="padding:6px 16px;border:1px solid #dddbd9;border-radius:20px;font-family:SpiegelSans4UI,Inter,sans-serif;font-size:12px;font-weight:600;color:#2f2d2b;cursor:pointer;transition:all 0.2s;background:#fff;">{f}</span>
            ))}
          </div>
        )}
      </div>
      {/* Bento Grid */}
      <div style="display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:220px;gap:12px;">
        {(a.items || []).map((item: any, i: number) => {
          const isLarge = item.size === 'large';
          const isWide = item.size === 'wide';
          const span = isLarge ? 'span 2 / span 2' : isWide ? 'span 2 / span 1' : 'span 1 / span 1';
          const gridCol = isLarge ? 'span 2' : isWide ? 'span 2' : 'span 1';
          const gridRow = isLarge ? 'span 2' : 'span 1';
          return (
            <a
              href={item.href || '#'}
              style={`grid-column:${gridCol};grid-row:${gridRow};position:relative;border-radius:8px;overflow:hidden;display:block;text-decoration:none;color:#fff;`}
            >
              {item.image && <img src={item.image} alt={item.title || ''} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" />}
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.7) 0%,rgba(0,0,0,0.1) 50%,rgba(0,0,0,0) 100%);"></div>
              <div style="position:absolute;bottom:0;left:0;right:0;padding:1.25rem;">
                {item.location && <p style="font-family:SpiegelSans4UI,Inter,sans-serif;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.7);margin-bottom:6px;">{item.location}</p>}
                <h3 style={`font-family:SpiegelSlab4UICd,Inter,sans-serif;font-weight:800;color:#fff;line-height:1.2;margin:0;font-size:${isLarge ? '1.5rem' : '1rem'};`}>{item.title}</h3>
                {item.description && isLarge && <p style="font-family:SpiegelSerifTextUI,serif;font-size:0.85rem;color:rgba(255,255,255,0.8);margin-top:6px;line-height:1.4;">{item.description}</p>}
                {item.price && <p style={`font-family:SpiegelSans4UI,Inter,sans-serif;font-weight:800;color:#fff;margin-top:8px;font-size:${isLarge ? '1.25rem' : '0.95rem'};`}>&euro; {item.price}</p>}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  );

  // Default: render standard WordPress blocks as HTML
  if (block.name?.startsWith('core/')) return (
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="font-body text-on-surface leading-relaxed prose prose-lg" set:html={block.innerHTML}></div>
    </div>
  );

  // Unknown block: render innerHTML if available
  if (block.innerHTML) return (
    <div class="max-w-7xl mx-auto px-6 py-4" set:html={block.innerHTML}></div>
  );

  return null;
})}
