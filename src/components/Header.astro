---

<header class="fixed top-0 left-0 right-0 h-16 bg-secondary z-50 flex items-center">
  <div class="w-full max-w-7xl mx-auto px-6 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="h-6">
      <img src="/uploads/spiegel-reisewelt-logo.png" alt="SPIEGEL Reisewelt" class="h-full w-auto object-contain" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="font-headline text-sm font-semibold text-on-secondary/90 hover:text-on-secondary transition-colors">
        Magazin
      </a>
      <a href="#ziele" class="font-headline text-sm font-semibold text-on-secondary/90 hover:text-on-secondary transition-colors">
        Ziele
      </a>
      <a href="#deals" class="font-headline text-sm font-semibold text-on-secondary/90 hover:text-on-secondary transition-colors">
        Deals
      </a>
    </nav>

    <!-- Icons -->
    <div class="flex items-center gap-4">
      <button class="text-on-secondary/90 hover:text-on-secondary transition-colors" aria-label="Suche">
        <span class="material-symbols-outlined text-[22px]">search</span>
      </button>
      <button class="md:hidden text-on-secondary/90 hover:text-on-secondary transition-colors" aria-label="Menü">
        <span class="material-symbols-outlined text-[22px]">menu</span>
      </button>
    </div>
  </div>
</header>
