---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Startseite', href: '/' },
  { label: 'Rundreisen', href: '/rundreisen' },
  { label: 'Genussreisen', href: '/genussreisen' },
  { label: 'Reisetrends', href: '/reisetrends' },
  { label: 'Über uns', href: '/ueber-uns' },
];
---

<!-- Partner Nav Bar -->
<div class="sticky top-0 z-30 spiegel-nav">
  <div class="w-full shadow bg-white">
    <nav role="navigation" class="border-t border-neutral-200">
      <div class="max-w-7xl mx-auto flex items-center h-12 px-4 md:px-6">
        <!-- Anzeige Label -->
        <div class="bg-neutral-100 px-3 py-1 font-headline text-[10px] uppercase tracking-widest text-neutral-500 rounded shrink-0">
          Anzeige
        </div>

        <!-- Desktop Nav Links (always visible on md+) -->
        <div class="hidden md:flex items-center h-full ml-6 gap-1">
          {navItems.map((item) => {
            const isActive = currentPath === item.href ||
              (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  'inline-flex items-center h-full px-4 font-headline text-[13px] transition-colors',
                  isActive
                    ? 'text-neutral-900 font-semibold border-b-2 border-[#E64415]'
                    : 'text-neutral-600 border-b-2 border-transparent hover:text-neutral-900 hover:border-neutral-300',
                ]}
              >
                {item.label}
              </a>
            );
          })}
        </div>

        <!-- Mobile: Hamburger -->
        <div class="flex items-center md:hidden ml-4">
          <button id="mobile-menu-toggle" class="flex items-center gap-2 text-neutral-900" aria-label="Menü öffnen">
            <span class="material-symbols-outlined text-[20px]">menu</span>
            <span class="font-headline text-sm">Menü</span>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu (hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-200 bg-white">
      <ul class="py-2">
        {navItems.map((item) => {
          const isActive = currentPath === item.href ||
            (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block px-6 py-3 font-headline text-sm transition-colors',
                  isActive
                    ? 'text-[#E64415] font-bold bg-neutral-50'
                    : 'text-neutral-700 hover:bg-neutral-50 hover:text-neutral-900',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
