---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "SPIEGEL Reisewelt – Kuratierte Reisemomente für den modernen Entdecker.",
  canonicalUrl = "https://reisewelt.spiegel.de"
} = Astro.props;

// Fetch SPIEGEL partner template at build time
let spiegelHead = '';
let spiegelHeader = '';
let spiegelFooter = '';
let useSpiegel = false;

try {
  const res = await fetch('https://www.spiegel.de/assets/partner/template-noads.html');
  if (res.ok) {
    const html = await res.text();

    // Extract <head> content (without SPIEGEL's main CSS to avoid conflicts)
    const headStart = html.indexOf('<head>') + 6;
    const headEnd = html.indexOf('</head>');
    let headContent = html.substring(headStart, headEnd)
      .replace(/###TITLE###/g, `${title} | SPIEGEL Reisewelt`)
      .replace(/###DESCRIPTION###/g, description)
      .replace(/###CANONICAL_URL###/g, canonicalUrl);

    // Keep SPIEGEL head but remove their main stylesheet to avoid conflicts
    // We only want their fonts, meta, and scripts — not their layout CSS
    headContent = headContent.replace(
      /<link[^>]*styles\.[a-f0-9]+\.css[^>]*>/g,
      '<!-- SPIEGEL styles removed to prevent conflicts -->'
    );

    spiegelHead = headContent;

    // Extract body header (from <body> to ###MAIN###)
    const bodyStart = html.indexOf('<body');
    const mainPos = html.indexOf('###MAIN###');
    spiegelHeader = html.substring(bodyStart, mainPos);

    // Extract footer (from after ###MAIN### to </html>)
    const mainEnd = mainPos + '###MAIN###'.length;
    const htmlEnd = html.lastIndexOf('</html>');
    spiegelFooter = html.substring(mainEnd, htmlEnd);

    useSpiegel = true;
  }
} catch {
  // SPIEGEL template unavailable — use standalone layout
}
---

{useSpiegel ? (
<html lang="de" class="print:text-xs">
  <head>
    <Fragment set:html={spiegelHead} />
    <!-- Reisewelt custom styles (loaded AFTER spiegel to take precedence) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Newsreader:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style is:global>
      /* Isolate Reisewelt content from SPIEGEL container */
      .reisewelt-content {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        overflow-x: hidden;
      }
      .reisewelt-content .spiegel-nav {
        position: sticky;
        top: 0;
        z-index: 30;
      }
      .reisewelt-content section,
      .reisewelt-content main,
      .reisewelt-content > footer {
        max-width: none !important;
      }
    </style>
  </head>
  <Fragment set:html={spiegelHeader} />
    <div class="reisewelt-content">
      <slot />
    </div>
  <Fragment set:html={spiegelFooter} />
</html>
) : (
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Newsreader:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <title>{title} | SPIEGEL Reisewelt</title>
  </head>
  <body class="bg-surface text-on-surface font-body">
    <slot />
  </body>
</html>
)}
