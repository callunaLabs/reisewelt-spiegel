---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "SPIEGEL Reisewelt – Kuratierte Reisemomente für den modernen Entdecker.",
  canonicalUrl = "https://reisewelt.spiegel.de"
} = Astro.props;

// Fetch SPIEGEL partner template at build time
let spiegelHead = '';
let spiegelHeader = '';
let spiegelFooter = '';
let useSpiegel = false;

try {
  const res = await fetch('https://www.spiegel.de/assets/partner/template-noads.html');
  if (res.ok) {
    const html = await res.text();

    // Extract <head> content (without SPIEGEL's main CSS to avoid conflicts)
    const headStart = html.indexOf('<head>') + 6;
    const headEnd = html.indexOf('</head>');
    let headContent = html.substring(headStart, headEnd)
      .replace(/###TITLE###/g, `${title} | SPIEGEL Reisewelt`)
      .replace(/###DESCRIPTION###/g, description)
      .replace(/###CANONICAL_URL###/g, canonicalUrl);

    // Keep ALL SPIEGEL styles — they need them for header/footer
    // We isolate our content with CSS @layer instead

    spiegelHead = headContent;

    // Extract body header (from <body> to ###MAIN###)
    const bodyStart = html.indexOf('<body');
    const mainPos = html.indexOf('###MAIN###');
    spiegelHeader = html.substring(bodyStart, mainPos);

    // Extract footer (from after ###MAIN### to </html>)
    const mainEnd = mainPos + '###MAIN###'.length;
    const htmlEnd = html.lastIndexOf('</html>');
    spiegelFooter = html.substring(mainEnd, htmlEnd);

    useSpiegel = true;
  }
} catch {
  // SPIEGEL template unavailable — use standalone layout
}
---

{useSpiegel ? (
<html lang="de" class="print:text-xs">
  <head>
    <Fragment set:html={spiegelHead} />
    <!-- Reisewelt custom styles (loaded AFTER spiegel to take precedence) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Newsreader:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style is:global>
      /*
       * CSS Isolation Strategy:
       * - SPIEGEL CSS controls everything OUTSIDE .reisewelt-content
       * - Our Tailwind controls everything INSIDE .reisewelt-content
       * - We scope our styles to avoid leaking into SPIEGEL header/footer
       */

      /* Break out of SPIEGEL container */
      .reisewelt-content {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        overflow-x: hidden;
        /* Reset SPIEGEL inherited styles */
        font-family: "Newsreader", serif;
        color: #1d1b16;
        line-height: 1.5;
      }
      .reisewelt-content .spiegel-nav {
        position: sticky;
        top: 0;
        z-index: 30;
      }
      /* Full-width sections (hero images, dark backgrounds) */
      .reisewelt-content section,
      .reisewelt-content main,
      .reisewelt-content > footer {
        max-width: none !important;
      }

      /* Content sections that need centered max-width */
      .reisewelt-content .max-w-7xl {
        max-width: 80rem !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      /* Font override: ensure Reisewelt fonts win over SPIEGEL globals */
      .reisewelt-content * {
        font-family: inherit;
      }
      .reisewelt-content h1,
      .reisewelt-content h2,
      .reisewelt-content h3,
      .reisewelt-content h4,
      .reisewelt-content [class*="font-headline"] {
        font-family: "Inter", sans-serif !important;
      }
      .reisewelt-content p,
      .reisewelt-content [class*="font-body"],
      .reisewelt-content article {
        font-family: "Newsreader", serif !important;
      }

      /* WordPress content styling */
      .reisewelt-content .wp-content h2 {
        font-family: "Inter", sans-serif !important;
        font-size: 1.5rem;
        font-weight: 800;
        margin: 2rem 0 1rem;
        color: #1d1b16;
      }
      .reisewelt-content .wp-content h3 {
        font-family: "Inter", sans-serif !important;
        font-size: 1.25rem;
        font-weight: 700;
        margin: 1.5rem 0 0.75rem;
        color: #1d1b16;
      }
      .reisewelt-content .wp-content p {
        font-family: "Newsreader", serif !important;
        font-size: 1.125rem;
        line-height: 1.8;
        margin-bottom: 1.25rem;
        color: #45464d;
      }
      .reisewelt-content .wp-content img {
        width: 100%;
        height: auto;
        border-radius: 0.25rem;
        margin: 2rem 0;
      }
      .reisewelt-content .wp-content ul,
      .reisewelt-content .wp-content ol {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }
      .reisewelt-content .wp-content li {
        font-family: "Newsreader", serif !important;
        font-size: 1.125rem;
        line-height: 1.8;
        margin-bottom: 0.5rem;
      }
      .reisewelt-content .wp-content a {
        color: #E64415;
        text-decoration: underline;
      }
      .reisewelt-content .wp-content figure {
        margin: 2rem 0;
      }
      .reisewelt-content .wp-content figcaption {
        font-family: "Inter", sans-serif !important;
        font-size: 0.75rem;
        color: #999;
        margin-top: 0.5rem;
      }
    </style>
  </head>
  <Fragment set:html={spiegelHeader} />
    <div class="reisewelt-content">
      <slot />
    </div>
  <Fragment set:html={spiegelFooter} />
</html>
) : (
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Newsreader:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <title>{title} | SPIEGEL Reisewelt</title>
  </head>
  <body class="bg-surface text-on-surface font-body">
    <slot />
  </body>
</html>
)}
