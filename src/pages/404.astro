---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Seite nicht gefunden">
  <Header />
  <main class="min-h-screen flex items-center justify-center bg-surface-container-low">
    <div class="max-w-2xl mx-auto px-6 text-center py-32">
      <div class="mb-8">
        <span class="text-[#E64415]/20" style="opacity:0.3;"><svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="#E64415" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
      </div>
      <h1 class="font-headline text-7xl md:text-9xl font-black text-primary tracking-tighter mb-4">404</h1>
      <p class="font-headline text-2xl md:text-3xl font-bold text-primary mb-4">Diese Reise existiert leider nicht.</p>
      <p class="font-body italic text-lg text-on-surface-variant mb-12 max-w-md mx-auto">
        Die gesuchte Seite wurde nicht gefunden. Vielleicht wurde sie verlegt &mdash; wie ein Reisepass vor dem Urlaub.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-[#E64415] text-white font-headline font-bold text-[11px] tracking-widest uppercase px-10 py-4 rounded-sm hover:bg-[#ff5a2b] transition-colors">
          Zur Startseite
        </a>
        <a href="/rundreisen" class="border-2 border-primary text-primary font-headline font-bold text-[11px] tracking-widest uppercase px-10 py-4 rounded-sm hover:bg-primary hover:text-white transition-colors">
          Rundreisen entdecken
        </a>
      </div>
      <div class="mt-16 pt-12 border-t border-outline-variant/30">
        <p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant/60 mb-6">Vielleicht interessiert Sie</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/genussreisen" class="font-headline text-sm font-semibold text-primary hover:text-[#E64415] transition-colors underline underline-offset-4 decoration-[#E64415]/30">Genussreisen</a>
          <span class="text-outline-variant">&middot;</span>
          <a href="/reisetrends" class="font-headline text-sm font-semibold text-primary hover:text-[#E64415] transition-colors underline underline-offset-4 decoration-[#E64415]/30">Reisetrends</a>
          <span class="text-outline-variant">&middot;</span>
          <a href="/ueber-uns" class="font-headline text-sm font-semibold text-primary hover:text-[#E64415] transition-colors underline underline-offset-4 decoration-[#E64415]/30">&Uuml;ber uns</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
