---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileNav from "../components/MobileNav.astro";
import { getHomepageData } from "../lib/wordpress";

let wpData = { rundreisen: [], genussreisen: [], reisetrends: [], deals: [] };
try {
  wpData = await getHomepageData();
} catch (e) {
  // WordPress unavailable, use static content below
}
---

<Layout title="Die Kunst des Ankommens">
  <Header />
  <MobileNav />

  <main class="pb-20 md:pb-0">
    <!-- ============================================ -->
    <!-- HERO SECTION                                 -->
    <!-- ============================================ -->
    <section class="relative h-[870px] overflow-hidden">
      <!-- Background Image -->
      <img
        src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80"
        alt="Tropischer Strand"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Gradient Overlay -->
      <div class="absolute inset-0 hero-gradient"></div>

      <!-- Hero Content -->
      <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-6 pb-40">
        <h1 class="font-headline text-6xl md:text-8xl font-black tracking-tighter text-white leading-[0.95]">
          Die Kunst des<br />Ankommens.
        </h1>
        <p class="font-body italic text-white/80 text-lg md:text-xl mt-5 max-w-xl">
          Kuratierte Reisemomente f&uuml;r den modernen Entdecker.
        </p>
      </div>

      <!-- Booking Widget -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 w-full max-w-5xl px-6">
        <div class="glass-panel rounded-[0.25rem] p-4 flex flex-col md:flex-row items-stretch gap-3">
          <!-- Wohin -->
          <div class="flex-1 flex items-center gap-3 px-4 py-3 bg-surface-container-low rounded-[0.25rem]">
            <span class="material-symbols-outlined text-on-surface-variant text-[20px]">flight_takeoff</span>
            <div>
              <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider">Wohin?</p>
              <p class="font-headline text-sm text-on-surface">Ziel eingeben</p>
            </div>
          </div>
          <!-- Zeitraum -->
          <div class="flex-1 flex items-center gap-3 px-4 py-3 bg-surface-container-low rounded-[0.25rem]">
            <span class="material-symbols-outlined text-on-surface-variant text-[20px]">calendar_month</span>
            <div>
              <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider">Zeitraum</p>
              <p class="font-headline text-sm text-on-surface">Datum w&auml;hlen</p>
            </div>
          </div>
          <!-- Reisende -->
          <div class="flex-1 flex items-center gap-3 px-4 py-3 bg-surface-container-low rounded-[0.25rem]">
            <span class="material-symbols-outlined text-on-surface-variant text-[20px]">group</span>
            <div>
              <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider">Reisende</p>
              <p class="font-headline text-sm text-on-surface">2 Erwachsene</p>
            </div>
          </div>
          <!-- Reiseart -->
          <div class="hidden md:flex flex-1 items-center gap-3 px-4 py-3 bg-surface-container-low rounded-[0.25rem]">
            <span class="material-symbols-outlined text-on-surface-variant text-[20px]">category</span>
            <div>
              <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider">Reiseart</p>
              <p class="font-headline text-sm text-on-surface">Alle Kategorien</p>
            </div>
          </div>
          <!-- Suchen Button -->
          <button class="bg-secondary hover:bg-secondary-container text-on-secondary font-headline font-bold text-sm px-8 py-4 rounded-[0.25rem] transition-colors shrink-0">
            Suchen
          </button>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- TRENDS SECTION                               -->
    <!-- ============================================ -->
    <section class="mt-40 max-w-7xl mx-auto px-6">
      <!-- Section Header -->
      <div class="mb-10">
        <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter text-on-surface">
          Trends.
        </h2>
        <p class="font-body text-on-surface-variant text-lg mt-2">
          Die meistgesuchten Ziele der Saison.
        </p>
      </div>

      <!-- Horizontal Scroll Cards -->
      <div class="flex gap-5 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-4">
        <!-- Card 1: Santorini -->
        <div class="snap-start shrink-0 w-[300px] md:w-[340px] group relative rounded-[0.25rem] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1613395877344-13d4a8e0d49e?w=800&q=80"
            alt="Santorini"
            class="w-full h-[450px] object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
          <div class="absolute top-4 left-4">
            <span class="font-headline text-6xl font-black text-white/20">01</span>
          </div>
          <div class="absolute bottom-6 left-5 right-5">
            <h3 class="font-headline text-xl font-bold text-white">Santorini</h3>
            <p class="font-body text-white/70 text-sm mt-1">Griechenland &middot; &Auml;g&auml;ische Tr&auml;ume</p>
          </div>
        </div>

        <!-- Card 2: Agra -->
        <div class="snap-start shrink-0 w-[300px] md:w-[340px] group relative rounded-[0.25rem] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1564507592333-c60657eea523?w=800&q=80"
            alt="Taj Mahal"
            class="w-full h-[450px] object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
          <div class="absolute top-4 left-4">
            <span class="font-headline text-6xl font-black text-white/20">02</span>
          </div>
          <div class="absolute bottom-6 left-5 right-5">
            <h3 class="font-headline text-xl font-bold text-white">Agra</h3>
            <p class="font-body text-white/70 text-sm mt-1">Indien &middot; Zeitlose Sch&ouml;nheit</p>
          </div>
        </div>

        <!-- Card 3: Ubud -->
        <div class="snap-start shrink-0 w-[300px] md:w-[340px] group relative rounded-[0.25rem] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=800&q=80"
            alt="Bali"
            class="w-full h-[450px] object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
          <div class="absolute top-4 left-4">
            <span class="font-headline text-6xl font-black text-white/20">03</span>
          </div>
          <div class="absolute bottom-6 left-5 right-5">
            <h3 class="font-headline text-xl font-bold text-white">Ubud</h3>
            <p class="font-body text-white/70 text-sm mt-1">Bali &middot; Spirituelle Ruhe</p>
          </div>
        </div>

        <!-- Card 4: Kyoto -->
        <div class="snap-start shrink-0 w-[300px] md:w-[340px] group relative rounded-[0.25rem] overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=800&q=80"
            alt="Kyoto"
            class="w-full h-[450px] object-cover group-hover:scale-105 transition-transform duration-500"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent"></div>
          <div class="absolute top-4 left-4">
            <span class="font-headline text-6xl font-black text-white/20">04</span>
          </div>
          <div class="absolute bottom-6 left-5 right-5">
            <h3 class="font-headline text-xl font-bold text-white">Kyoto</h3>
            <p class="font-body text-white/70 text-sm mt-1">Japan &middot; Tradition & Moderne</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- CURATED GRID SECTION                         -->
    <!-- ============================================ -->
    <section id="ziele" class="bg-surface-container-low mt-32 py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <!-- Left Column: Sticky Text -->
          <div class="lg:sticky lg:top-32 lg:self-start">
            <p class="font-label text-xs font-semibold text-secondary uppercase tracking-widest mb-4">Kuratiert</p>
            <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter text-on-surface leading-[1.05]">
              Ziele der<br />Sehnsucht.
            </h2>
            <p class="font-body text-on-surface-variant text-lg mt-6 max-w-md leading-relaxed">
              Handverlesene Destinationen, die weit &uuml;ber das Gew&ouml;hnliche hinausgehen. Jedes Ziel erz&auml;hlt seine eigene Geschichte.
            </p>
            <a
              href="/rundreisen"
              class="inline-flex items-center gap-2 mt-8 font-headline text-sm font-bold text-secondary hover:text-secondary-container transition-colors"
            >
              Alle Rundreisen entdecken
              <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
          </div>

          <!-- Right Column: 2-Col Grid with Offset -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <!-- Card 1: Alpine Hideaways -->
            <div class="group relative rounded-[0.25rem] overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=800&q=80"
                alt="Alpine Hideaways"
                class="w-full h-[340px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
              <div class="absolute top-4 right-4">
                <span class="glass-panel px-3 py-1 rounded-[0.25rem] font-headline text-xs font-bold text-on-surface">ab 899&euro;</span>
              </div>
              <div class="absolute bottom-5 left-5 right-5">
                <h3 class="font-headline text-lg font-bold text-white">Alpine Hideaways</h3>
                <p class="font-body text-white/70 text-sm mt-1">Bergrefugien der Stille</p>
              </div>
            </div>

            <!-- Card 2: Private Islands (offset) -->
            <div class="group relative rounded-[0.25rem] overflow-hidden translate-y-0 sm:translate-y-12">
              <img
                src="https://images.unsplash.com/photo-1514282401047-d79a71a590e8?w=800&q=80"
                alt="Private Islands"
                class="w-full h-[340px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
              <div class="absolute top-4 right-4">
                <span class="glass-panel px-3 py-1 rounded-[0.25rem] font-headline text-xs font-bold text-on-surface">ab 2.499&euro;</span>
              </div>
              <div class="absolute bottom-5 left-5 right-5">
                <h3 class="font-headline text-lg font-bold text-white">Private Islands</h3>
                <p class="font-body text-white/70 text-sm mt-1">Exklusive Inselparadiese</p>
              </div>
            </div>

            <!-- Card 3: Urban Oasis -->
            <div class="group relative rounded-[0.25rem] overflow-hidden">
              <img
                src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800&q=80"
                alt="Urban Oasis"
                class="w-full h-[340px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
              <div class="absolute top-4 right-4">
                <span class="glass-panel px-3 py-1 rounded-[0.25rem] font-headline text-xs font-bold text-on-surface">ab 1.200&euro;</span>
              </div>
              <div class="absolute bottom-5 left-5 right-5">
                <h3 class="font-headline text-lg font-bold text-white">Urban Oasis</h3>
                <p class="font-body text-white/70 text-sm mt-1">St&auml;dtische Ruheoasen</p>
              </div>
            </div>

            <!-- Card 4: Coastal Elegance (offset) -->
            <div class="group relative rounded-[0.25rem] overflow-hidden translate-y-0 sm:translate-y-12">
              <img
                src="https://images.unsplash.com/photo-1534308983496-4fabb1a015ee?w=800&q=80"
                alt="Coastal Elegance"
                class="w-full h-[340px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
              <div class="absolute top-4 right-4">
                <span class="glass-panel px-3 py-1 rounded-[0.25rem] font-headline text-xs font-bold text-on-surface">ab 1.599&euro;</span>
              </div>
              <div class="absolute bottom-5 left-5 right-5">
                <h3 class="font-headline text-lg font-bold text-white">Coastal Elegance</h3>
                <p class="font-body text-white/70 text-sm mt-1">K&uuml;stenmagie pur</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- EDITOR'S PICK SECTION                        -->
    <!-- ============================================ -->
    <section class="py-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- Large watermark text -->
          <div class="absolute -left-8 top-1/2 -translate-y-1/2 pointer-events-none select-none hidden lg:block">
            <span class="font-headline text-[200px] font-black text-surface-container-high/60 leading-none tracking-tighter">
              EDITS
            </span>
          </div>

          <!-- Left: Image Composition -->
          <div class="relative z-10">
            <div class="relative">
              <img
                src="https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=800&q=80"
                alt="Paris"
                class="w-full h-[500px] object-cover rounded-[0.25rem]"
              />
              <!-- Floating stats card -->
              <div class="absolute -bottom-6 -right-4 md:-right-8 glass-panel rounded-[0.25rem] p-5 shadow-lg">
                <div class="flex gap-8">
                  <div class="text-center">
                    <p class="font-headline text-3xl font-black text-secondary">12</p>
                    <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-widest">Hotspots</p>
                  </div>
                  <div class="text-center">
                    <p class="font-headline text-3xl font-black text-secondary">03</p>
                    <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-widest">Viertel</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Text Content -->
          <div class="relative z-10 lg:pl-8">
            <p class="font-label text-xs font-semibold text-secondary uppercase tracking-widest mb-4">Editor&apos;s Pick</p>
            <h2 class="font-headline text-4xl md:text-5xl font-black tracking-tighter text-on-surface leading-[1.05]">
              72 Stunden in Paris: Ein Guide f&uuml;r Genie&szlig;er.
            </h2>
            <p class="font-body text-on-surface-variant text-lg mt-6 leading-relaxed max-w-lg">
              Vergessen Sie den Louvre. Wir f&uuml;hren Sie zu den versteckten Ateliers von Belleville, den besten Naturweinen im 11. Arrondissement und einem Fr&uuml;hst&uuml;ck mit Blick auf die D&auml;cher von Montmartre.
            </p>
            <a
              href="/reisetrends/reisetrends-2026"
              class="inline-flex items-center gap-2 mt-8 font-headline text-sm font-bold text-secondary hover:text-secondary-container transition-colors"
            >
              Artikel lesen
              <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- DEALS SECTION                                -->
    <!-- ============================================ -->
    <section id="deals" class="bg-primary py-24">
      <div class="max-w-7xl mx-auto px-6">
        <!-- Section Header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-6">
          <div>
            <h2 class="font-headline text-5xl md:text-6xl font-black tracking-tighter text-on-primary">
              Deals der Woche.
            </h2>
            <p class="font-body text-on-primary/60 text-lg mt-2">
              Exklusive Angebote, nur f&uuml;r kurze Zeit.
            </p>
          </div>
          <!-- Countdown Timer -->
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-on-primary/40 text-[20px]">timer</span>
            <div class="flex items-center gap-2 font-headline text-on-primary">
              <div class="bg-primary-container px-3 py-2 rounded-[0.25rem] text-center">
                <span class="text-xl font-bold block" id="days">02</span>
                <span class="text-[9px] uppercase tracking-wider text-on-primary-container font-semibold">Tage</span>
              </div>
              <span class="text-on-primary/30 font-bold">:</span>
              <div class="bg-primary-container px-3 py-2 rounded-[0.25rem] text-center">
                <span class="text-xl font-bold block" id="hours">14</span>
                <span class="text-[9px] uppercase tracking-wider text-on-primary-container font-semibold">Std</span>
              </div>
              <span class="text-on-primary/30 font-bold">:</span>
              <div class="bg-primary-container px-3 py-2 rounded-[0.25rem] text-center">
                <span class="text-xl font-bold block" id="minutes">38</span>
                <span class="text-[9px] uppercase tracking-wider text-on-primary-container font-semibold">Min</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Deals Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          <!-- Deal 1: Soneva Fushi -->
          <div class="bg-primary-container rounded-[0.25rem] overflow-hidden group">
            <div class="relative">
              <img
                src="https://images.unsplash.com/photo-1514282401047-d79a71a590e8?w=800&q=80"
                alt="Soneva Fushi"
                class="w-full h-[200px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-secondary text-on-secondary font-headline text-xs font-bold px-2.5 py-1 rounded-[0.25rem]">-35%</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-0.5 mb-2">
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
              </div>
              <h3 class="font-headline text-base font-bold text-on-primary">Soneva Fushi Resort</h3>
              <p class="font-body text-on-primary-container text-sm mt-1">Malediven</p>
              <div class="mt-4 flex items-baseline gap-2">
                <span class="font-headline text-2xl font-black text-on-primary">&euro;3.490</span>
                <span class="font-body text-sm text-on-primary-container line-through">&euro;5.200</span>
              </div>
              <button class="mt-4 w-full bg-secondary hover:bg-secondary-container text-on-secondary font-headline text-sm font-bold py-3 rounded-[0.25rem] transition-colors">
                Jetzt buchen
              </button>
            </div>
          </div>

          <!-- Deal 2: Hotel de Russie -->
          <div class="bg-primary-container rounded-[0.25rem] overflow-hidden group">
            <div class="relative">
              <img
                src="https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=800&q=80"
                alt="Hotel de Russie"
                class="w-full h-[200px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-secondary text-on-secondary font-headline text-xs font-bold px-2.5 py-1 rounded-[0.25rem]">-20%</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-0.5 mb-2">
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
              </div>
              <h3 class="font-headline text-base font-bold text-on-primary">Hotel de Russie</h3>
              <p class="font-body text-on-primary-container text-sm mt-1">Rom, Italien</p>
              <div class="mt-4 flex items-baseline gap-2">
                <span class="font-headline text-2xl font-black text-on-primary">&euro;1.150</span>
                <span class="font-body text-sm text-on-primary-container line-through">&euro;1.440</span>
              </div>
              <button class="mt-4 w-full bg-secondary hover:bg-secondary-container text-on-secondary font-headline text-sm font-bold py-3 rounded-[0.25rem] transition-colors">
                Jetzt buchen
              </button>
            </div>
          </div>

          <!-- Deal 3: Sahara Luxury Camp -->
          <div class="bg-primary-container rounded-[0.25rem] overflow-hidden group">
            <div class="relative">
              <img
                src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800&q=80"
                alt="Sahara Luxury Camp"
                class="w-full h-[200px] object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute top-3 left-3">
                <span class="bg-secondary text-on-secondary font-headline text-xs font-bold px-2.5 py-1 rounded-[0.25rem]">Flash</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-0.5 mb-2">
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star</span>
                <span class="material-symbols-outlined text-amber-400 text-[16px]">star_half</span>
              </div>
              <h3 class="font-headline text-base font-bold text-on-primary">Sahara Luxury Camp</h3>
              <p class="font-body text-on-primary-container text-sm mt-1">Marokko</p>
              <div class="mt-4 flex items-baseline gap-2">
                <span class="font-headline text-2xl font-black text-on-primary">&euro;890</span>
              </div>
              <button class="mt-4 w-full bg-secondary hover:bg-secondary-container text-on-secondary font-headline text-sm font-bold py-3 rounded-[0.25rem] transition-colors">
                Jetzt buchen
              </button>
            </div>
          </div>

          <!-- Deal 4: Chalet Zermatt Peak -->
