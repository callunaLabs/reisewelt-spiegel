---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileNav from "../components/MobileNav.astro";
import { getHomepageData } from "../lib/wordpress";

let wpData = { rundreisen: [], genussreisen: [], reisetrends: [], deals: [] };
try {
  wpData = await getHomepageData();
} catch (e) {
  // WordPress unavailable, use static content below
}

// Static featured trips data (fallback / default)
const featuredTrips = [
  {
    title: "Azoren: Inselhopping im Atlantik",
    category: "Rundreise",
    price: "ab 2.495 \u20AC p.P.",
    duration: "11 Tage",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/5/6/csm_azoren4_063dfb628c.webp",
    href: "/rundreisen/azoren",
    isAd: true,
  },
  {
    title: "Katalonien abseits von Barcelona",
    category: "Genussreise",
    price: "ab 3.115 \u20AC p.P.",
    duration: "7 Tage",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/2/1/csm_Katalonien_Fischerboote_b8913155bf.jpg",
    href: "/genussreisen/katalonien",
    isAd: true,
  },
  {
    title: "Reisetrends 2026: Wie Urlaub heute aussieht",
    category: "Reisetrend",
    price: null,
    duration: null,
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/6/f/csm_Bild_1_Credit_Oleh_Slobodeniuk_2875x1250px_18c8f2f284.webp",
    href: "/reisetrends/reisetrends-2026",
    isAd: false,
  },
  {
    title: "S\u00FCdwestfrankreich",
    category: "Genussreise",
    price: "ab 3.589 \u20AC p.P.",
    duration: "8 Tage",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/c/1/csm_chateaulesmerles0__1__b53e8c31c2.jpg",
    href: "/genussreisen/suedwestfrankreich",
    isAd: true,
  },
  {
    title: "Nordmazedonien, Albanien & Montenegro",
    category: "Rundreise",
    price: "ab 1.695 \u20AC p.P.",
    duration: "10 Tage",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/c/d/csm_962247-373195-1_18dbfb6cd4.jpg",
    href: "/rundreisen/nordmazedonien-albanien-montenegro",
    isAd: true,
  },
  {
    title: "Eventkreuzfahrten: Motto-Reisen auf See",
    category: "Reisetrend",
    price: null,
    duration: null,
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/6/d/csm_Bild_1_Credit_TUI-Cruises-GmbH_-Mein-Schiff_847aaf83b5.jpg",
    href: "/reisetrends/eventkreuzfahrten",
    isAd: false,
  },
];

const categories = [
  {
    title: "Genussreisen",
    tagline: "Genussvolle Gruppenreisen in Europa",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/4/e/csm_Teaser_Genussreisen_Kategorie_23f28543a9.jpg",
    href: "/genussreisen",
  },
  {
    title: "Rundreisen",
    tagline: "Die Welt entdecken",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/b/7/csm_china6_77426331b0.webp",
    href: "/rundreisen",
  },
  {
    title: "Reisetrends",
    tagline: "Wie Reisen heute aussieht",
    image: "https://reisewelt.spiegel.de/fileadmin/_processed_/f/5/csm_Bild_2_Credit_Pekic_1280x960px_0392b6dbfd.jpg",
    href: "/reisetrends",
  },
];

const spiegelArticles = [
  {
    title: "Italien: B\u00FCrgermeister von Vallecrosia will mit Zusatz \u00BBal mare\u00AB um Touristen werben",
    date: "22. M\u00E4rz 2026",
    image: "https://cdn.prod.www.spiegel.de/images/c65a2108-78b2-43b7-93e0-03b94a5dcec5_w520_r2.08_fpx41.97_fpy48.99.jpg",
    href: "https://www.spiegel.de/reise/",
  },
  {
    title: "Iran-Krieg: \u00BBDie erh\u00F6hten Flugpreise k\u00F6nnen noch eine Zeit lang anhalten\u00AB",
    date: "20. M\u00E4rz 2026",
    image: "https://cdn.prod.www.spiegel.de/images/750cf046-ef2d-4d1c-96d0-90bc78412e76_w520_r2.08_fpx44.7_fpy50.98.jpg",
    href: "https://www.spiegel.de/reise/",
  },
  {
    title: "JLoup: Der Mann, der sich 4200 Kilometer bis zum Nordkap zeichnete",
    date: "17. M\u00E4rz 2026",
    image: "https://cdn.prod.www.spiegel.de/images/4cb65734-d0b6-4a2c-b85c-98d3295ee28f_w520_r2.08_fpx22_fpy57.jpg",
    href: "https://www.spiegel.de/reise/",
  },
  {
    title: "Dresden\u2013Prag: Monatelange Sperrungen auf Bahnstrecke beginnen",
    date: "15. M\u00E4rz 2026",
    image: "https://cdn.prod.www.spiegel.de/images/9d2f4fae-0f23-4c4e-8c05-8e45ebf63d54_w520_r2.08_fpx43.3_fpy49.99.jpg",
    href: "https://www.spiegel.de/reise/",
  },
];

const faqItems = [
  {
    question: "Was ist die SPIEGEL Reisewelt?",
    answer: "Die SPIEGEL Reisewelt ist eine kuratierte Reiseplattform, auf der ausgew\u00E4hlte Reiseangebote von vertrauensw\u00FCrdigen Partnern pr\u00E4sentiert werden. Die Redaktion stellt Rundreisen, Genussreisen und redaktionelle Reisetrends zusammen, die den hohen Qualit\u00E4tsanspr\u00FCchen des SPIEGEL entsprechen. Ziel ist es, Leserinnen und Lesern inspirierende Reiseerlebnisse zu bieten, die sorgf\u00E4ltig gepr\u00FCft und zusammengestellt wurden.",
  },
  {
    question: "Wie funktioniert die Buchung \u00FCber die SPIEGEL Reisewelt?",
    answer: "Die SPIEGEL Reisewelt vermittelt zwischen Reisenden und erfahrenen Reiseveranstaltern. Wenn Sie sich f\u00FCr ein Angebot interessieren, werden Sie direkt zur Buchungsseite des jeweiligen Partners weitergeleitet. Dort k\u00F6nnen Sie alle Details einsehen und Ihre Reise verbindlich buchen. Der Reiseveranstalter ist Ihr direkter Vertragspartner und steht Ihnen f\u00FCr alle Fragen rund um Ihre Buchung zur Verf\u00FCgung.",
  },
  {
    question: "Verdient der SPIEGEL an meiner Buchung?",
    answer: "Ja, der SPIEGEL erh\u00E4lt f\u00FCr die Vermittlung eine Provision vom Reiseveranstalter. F\u00FCr Sie als Reisende entstehen dadurch keine Mehrkosten \u2013 der Reisepreis bleibt derselbe, als w\u00FCrden Sie direkt beim Veranstalter buchen. Die Einnahmen aus der Reisewelt unterst\u00FCtzen den unabh\u00E4ngigen Journalismus des SPIEGEL.",
  },
];
---

<Layout title="SPIEGEL Reisewelt">
  <Header />
  <MobileNav />

  <main class="pb-20 md:pb-0">
    <!-- ============================================ -->
    <!-- SECTION 1: HERO                              -->
    <!-- ============================================ -->
    <section class="relative h-[600px] md:h-[700px] overflow-hidden">
      <!-- Background Image -->
      <img
        src="https://reisewelt.spiegel.de/fileadmin/_processed_/5/6/csm_azoren4_063a01fb8d.webp"
        alt="Azoren Panorama"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <!-- Gradient Overlay -->
      <div class="absolute inset-0 hero-gradient"></div>

      <!-- Hero Content -->
      <div class="relative z-10 h-full flex flex-col justify-end max-w-7xl mx-auto px-6 pb-16 md:pb-24">
        <h1 class="font-headline text-3xl md:text-5xl lg:text-6xl font-black tracking-tighter text-white leading-[1.05] max-w-3xl">
          SPIEGEL Reisewelt &ndash; schon die n&auml;chste Reise geplant?
        </h1>
        <p class="font-body italic text-white/80 text-base md:text-lg mt-4 max-w-2xl leading-relaxed">
          Auf dieser Seite finden Sie Reiseangebote, die wir zusammen mit unseren Reisepartnern f&uuml;r Sie zusammengestellt haben.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/rundreisen"
            class="inline-flex items-center gap-2 bg-secondary hover:bg-secondary-container text-on-secondary font-headline text-sm font-bold px-6 py-3 rounded-[0.25rem] transition-colors"
          >
            Rundreisen entdecken
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          </a>
          <a
            href="/genussreisen"
            class="inline-flex items-center gap-2 glass-panel text-on-surface font-headline text-sm font-bold px-6 py-3 rounded-[0.25rem] hover:bg-white transition-colors"
          >
            Genussreisen
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 2: FEATURED TRIPS SLIDER             -->
    <!-- ============================================ -->
    <section class="mt-16 md:mt-24 max-w-7xl mx-auto px-6">
      <!-- Section Header -->
      <div class="mb-8">
        <h2 class="font-headline text-3xl md:text-4xl font-black tracking-tight text-on-surface">
          Reiseerlebnisse finden &amp; buchen
        </h2>
        <p class="font-body text-on-surface-variant text-base md:text-lg mt-2">
          Ausgew&auml;hlte Angebote unserer Reisepartner.
        </p>
      </div>

      <!-- Horizontal Scroll Cards -->
      <div class="flex gap-5 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-4">
        {featuredTrips.map((trip) => (
          <a
            href={trip.href}
            class="snap-start shrink-0 w-[280px] md:w-[320px] group relative rounded-[0.25rem] overflow-hidden block"
          >
            <img
              src={trip.image}
              alt={trip.title}
              class="w-full h-[420px] object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/10 to-transparent"></div>

            {/* Category Tag + Anzeige */}
            <div class="absolute top-4 left-4 flex items-center gap-2">
              <span class="bg-secondary text-on-secondary font-headline text-[11px] font-bold px-2.5 py-1 rounded-[0.25rem]">
                {trip.category}
              </span>
              {trip.isAd && (
                <span class="bg-white/20 backdrop-blur-sm text-white font-headline text-[10px] font-semibold px-2 py-0.5 rounded-[0.25rem]">
                  Anzeige
                </span>
              )}
            </div>

            {/* Content */}
            <div class="absolute bottom-5 left-5 right-5">
              <h3 class="font-headline text-lg font-bold text-white leading-snug">
                {trip.title}
              </h3>
              <div class="flex items-center gap-3 mt-2">
                {trip.price && (
                  <span class="font-headline text-sm font-bold text-white">
                    {trip.price}
                  </span>
                )}
                {trip.duration && (
                  <span class="font-body text-white/70 text-sm">
                    {trip.duration}
                  </span>
                )}
                {!trip.price && !trip.duration && (
                  <span class="font-body text-white/70 text-sm italic">
                    Redaktioneller Beitrag
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 3: CATEGORY GRID                     -->
    <!-- ============================================ -->
    <section class="mt-20 md:mt-28 max-w-7xl mx-auto px-6">
      <!-- Section Header -->
      <div class="mb-10">
        <h2 class="font-headline text-3xl md:text-4xl font-black tracking-tight text-on-surface">
          Unsere Reisekategorien
        </h2>
      </div>

      <!-- 3-Column Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="group relative rounded-[0.25rem] overflow-hidden block h-[360px] md:h-[420px]"
          >
            <img
              src={cat.image}
              alt={cat.title}
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/20 to-transparent group-hover:from-primary/80 transition-all duration-300"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <h3 class="font-headline text-2xl font-black text-white tracking-tight">
                {cat.title}
              </h3>
              <p class="font-body text-white/80 text-sm mt-1 italic">
                {cat.tagline}
              </p>
              <span class="inline-flex items-center gap-1 mt-3 font-headline text-sm font-bold text-white group-hover:gap-2 transition-all">
                Entdecken
                <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 4: SPIEGEL REISE ARTICLES            -->
    <!-- ============================================ -->
    <section class="mt-20 md:mt-28 bg-surface-container-low py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6">
        <!-- Section Header -->
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="font-label text-xs font-semibold text-secondary uppercase tracking-widest mb-2">Redaktion</p>
            <h2 class="font-headline text-3xl md:text-4xl font-black tracking-tight text-on-surface">
              SPIEGEL Reise
            </h2>
          </div>
          <a
            href="https://www.spiegel.de/reise/"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:inline-flex items-center gap-1 font-headline text-sm font-bold text-secondary hover:text-secondary-container transition-colors"
          >
            Alle Artikel
            <span class="material-symbols-outlined text-[16px]">open_in_new</span>
          </a>
        </div>

        <!-- Articles Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {spiegelArticles.map((article) => (
            <a
              href={article.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group block rounded-[0.25rem] overflow-hidden bg-surface hover:shadow-lg transition-shadow duration-300"
            >
              <div class="relative overflow-hidden">
                <img
                  src={article.image}
                  alt={article.title}
                  class="w-full h-[180px] object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <p class="font-label text-[11px] font-semibold text-on-surface-variant uppercase tracking-wide">
                  {article.date}
                </p>
                <h3 class="font-headline text-sm font-bold text-on-surface mt-1 leading-snug group-hover:text-secondary transition-colors">
                  {article.title}
                </h3>
                <span class="inline-flex items-center gap-1 mt-3 font-headline text-xs font-bold text-secondary">
                  Auf spiegel.de lesen
                  <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                </span>
              </div>
            </a>
          ))}
        </div>

        <!-- Mobile "Alle Artikel" link -->
        <div class="mt-6 md:hidden text-center">
          <a
            href="https://www.spiegel.de/reise/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 font-headline text-sm font-bold text-secondary"
          >
            Alle Artikel auf spiegel.de
            <span class="material-symbols-outlined text-[16px]">open_in_new</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 5: SIDEBAR WIDGETS (INLINE)          -->
    <!-- ============================================ -->
    <section class="mt-20 md:mt-28 max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- eSIM Widget -->
        <div class="rounded-[0.25rem] border border-outline-variant/30 bg-surface-container-low p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-[32px] shrink-0 mt-1">sim_card</span>
            <div>
              <p class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-widest mb-1">Partner</p>
              <h3 class="font-headline text-lg font-bold text-on-surface">WonderConnect eSIM</h3>
              <p class="font-body text-on-surface-variant text-sm mt-2 leading-relaxed">
                Bleiben Sie im Urlaub verbunden &ndash; mit g&uuml;nstigen eSIM-Datentarifen f&uuml;r &uuml;ber 190 L&auml;nder. Kein SIM-Kartenwechsel n&ouml;tig, einfach per QR-Code aktivieren.
              </p>
              <a
                href="https://www.wonderconnect.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 mt-4 font-headline text-sm font-bold text-secondary hover:text-secondary-container transition-colors"
              >
                eSIM bestellen
                <span class="material-symbols-outlined text-[16px]">open_in_new</span>
              </a>
              <p class="font-label text-[10px] text-on-surface-variant mt-2">Anzeige</p>
            </div>
          </div>
        </div>

        <!-- Newsletter Widget -->
        <div class="rounded-[0.25rem] border border-outline-variant/30 bg-surface-container-low p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-secondary text-[32px] shrink-0 mt-1">mail</span>
            <div class="w-full">
              <p class="font-label text-[10px] font-semibold text-secondary uppercase tracking-widest mb-1">Newsletter</p>
              <h3 class="font-headline text-lg font-bold text-on-surface">SPIEGEL &bdquo;Gute Reise&ldquo;</h3>
              <p class="font-body text-on-surface-variant text-sm mt-2 leading-relaxed">
                Jede Woche die besten Reisetipps, Reportagen und Angebote direkt in Ihr Postfach. Kostenlos abonnieren und keine Reise-Inspiration mehr verpassen.
              </p>
              <form class="mt-4 flex flex-col sm:flex-row gap-2" onsubmit="return false;">
                <input
                  type="email"
                  placeholder="Ihre E-Mail-Adresse"
                  class="flex-1 px-4 py-2.5 rounded-[0.25rem] border border-outline-variant/40 bg-surface font-body text-sm text-on-surface placeholder:text-on-surface-variant/50 focus:outline-none focus:border-secondary transition-colors"
                />
                <button
                  type="submit"
                  class="bg-secondary hover:bg-secondary-container text-on-secondary font-headline text-sm font-bold px-5 py-2.5 rounded-[0.25rem] transition-colors shrink-0"
                >
                  Abonnieren
                </button>
              </form>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================ -->
    <!-- SECTION 6: FAQ                               -->
    <!-- ============================================ -->
    <section class="mt-20 md:mt-28 mb-16 max-w-3xl mx-auto px-6">
      <!-- Section Header -->
      <div class="mb-8 text-center">
        <h2 class="font-headline text-3xl md:text-4xl font-black tracking-tight text-on-surface">
          H&auml;ufige Fragen
        </h2>
      </div>

      <!-- FAQ Items -->
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-[0.25rem] border border-outline-variant/30 bg-surface-container-low overflow-hidden">
            <summary class="flex items-center justify-between gap-4 cursor-pointer p-5 md:p-6 list-none [&::-webkit-details-marker]:hidden">
              <h3 class="font-headline text-base font-bold text-on-surface">
                {item.question}
              </h3>
              <span class="material-symbols-outlined text-on-surface-variant text-[20px] shrink-0 transition-transform duration-200 group-open:rotate-180">
                expand_more
              </span>
            </summary>
            <div class="px-5 pb-5 md:px-6 md:pb-6 -mt-1">
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">
                {item.answer}
              </p>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer variant="full" />
</Layout>
